# ─────────────────────────────────────────────────────────────────────────────
# AuctionService Environment Variables
# Copy this file to .env and fill in the values before running.
# ─────────────────────────────────────────────────────────────────────────────

# ASP.NET Core
ASPNETCORE_ENVIRONMENT=Development

# PostgreSQL
POSTGRES_USER=auctionuser
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=auctionservice

# Connection String (used by the API)
# Format: Host=localhost;Port=5432;Database=auctionservice;Username=auctionuser;Password=<POSTGRES_PASSWORD>
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=auctionservice;Username=auctionuser;Password=change_me_in_production

# JWT (minimum 32 characters)
JWT_SECRET=change_me_secret_minimum_32_chars_long
JWT_ISSUER=AuctionService
JWT_AUDIENCE=AuctionService
JWT_EXPIRY_MINUTES=60

# pgAdmin
PGADMIN_PASSWORD=pgadmin_password
